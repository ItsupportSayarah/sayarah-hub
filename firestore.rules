rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: Check if user is authenticated ───
    function isAuth() {
      return request.auth != null;
    }

    // ─── Helper: Super admin — hardcoded email, rules can't read env ─
    // Must stay in sync with SUPER_ADMIN_EMAIL in apps/auction/src/firebase.js
    // and VITE_SUPER_ADMIN_EMAIL. Super admin is recognized by token
    // email directly so admin powers work even before a Firestore doc
    // with role=admin has been created for them.
    function isSuperAdmin() {
      return isAuth() && request.auth.token.email == "support@sayarah.io";
    }

    // ─── Helper: Check if user is admin by reading their user doc ───
    // Super admin bypass first so an initial write (before the
    // sync-on-signin fires) isn't blocked by a stale role field.
    function isAdmin() {
      return isSuperAdmin() || (isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // ─── Helper: Check if user is admin or manager ───
    function isAdminOrManager() {
      return isSuperAdmin() || (isAuth() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "manager"
      ));
    }

    // ─── Users collection ───
    // Users can read/write their own doc; admins can read/write all.
    // Plus: a user can read/update/delete any doc whose `email` field
    // matches their auth token email — needed so a freshly signed-in
    // user can migrate the placeholder doc that "Add User" created
    // (keyed by email, not by Firebase UID) into a UID-keyed doc and
    // then clean up the orphan. Without this, the user signs in but
    // gets a fresh doc with no `auctionAccess`, locking them out.
    function emailMatches() {
      return resource != null
        && resource.data.email is string
        && request.auth.token.email is string
        && resource.data.email.lower() == request.auth.token.email.lower();
    }
    match /users/{uid} {
      allow read: if isAuth() && (
        request.auth.uid == uid || emailMatches() || isAdminOrManager()
      );
      allow create: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow update, delete: if isAuth() && (
        request.auth.uid == uid || emailMatches() || isAdmin()
      );
    }

    // ─── Auction Shared Data (vehicles, expenses, sales) ───
    // Any authenticated user with auction access can read
    // Only admin/manager can write
    match /auctionShared/{docId} {
      allow read: if isAuth();
      allow write: if isAdminOrManager();
    }

    // ─── Auction Per-User Data (legacy, migration) ───
    match /auctionData/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ─── Logistics Shared Data ───
    match /logisticsShared/{docId} {
      allow read: if isAuth();
      allow write: if isAdminOrManager();
    }

    // ─── Logistics Per-User Data (legacy) ───
    match /logisticsData/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ─── Activity Log — append-only audit trail ───
    // Any authenticated user can create (append) an entry. No one can
    // update or delete — the log is immutable at the rules layer.
    match /activityLog/{entryId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ─── Deny everything else by default ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
