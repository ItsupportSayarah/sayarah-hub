// Firebase Storage security rules.
//
// Deploy with:  firebase deploy --only storage
//
// Before this file existed, Storage rules lived only in the Firebase
// Console. If the Console rules were the default-deny
// ("allow read, write: if false;"), authenticated users saw uploads
// silently fail — which was the "clients cannot upload photos"
// symptom we were debugging. These rules make the intent explicit
// and version-controlled.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Vehicle photos (Auto Trade Hub inventory) ───
    // Any authenticated user can upload / overwrite / delete photos on a
    // vehicle. Writes are capped at 10 MB per file and must be an image.
    match /vehicles/{vehicleId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                && request.resource.size < 10 * 1024 * 1024
                && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // ─── Vehicle documents (title scans, receipts, etc.) ───
    // Bigger size cap since documents can be multi-page PDFs.
    match /vehicles/{vehicleId}/documents/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                && request.resource.size < 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // ─── Deny everything else by default ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
